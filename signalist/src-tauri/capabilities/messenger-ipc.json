{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "messenger-ipc",
  "description": "IPC access for messenger webviews (Telegram, WhatsApp) to report unread counts to the backend",
  "windows": ["main"],
  "webviews": ["telegram", "whatsapp"],
  "remote": {
    "urls": [
      "https://web.telegram.org/*",
      "https://t.me/*",
      "https://web.whatsapp.com/*"
    ]
  },
  "permissions": [
    "core:default",
    "allow-update-unread-count"
  ]
}
