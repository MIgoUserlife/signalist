{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Signalist",
  "version": "0.3.4",
  "identifier": "com.signalist.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Signalist",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "create": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset: tauri:",
        "connect-src": "ipc: http://ipc.localhost https://web.telegram.org https://web.whatsapp.com",
        "img-src": "'self' asset: http://asset.localhost blob: data: https://web.telegram.org https://web.whatsapp.com",
        "style-src": "'unsafe-inline' 'self'",
        "script-src": "'self'",
        "font-src": "https://fonts.gstatic.com https://web.telegram.org https://web.whatsapp.com",
        "media-src": "blob: https://web.telegram.org https://web.whatsapp.com",
        "worker-src": "'self' blob:"
      },
      "capabilities": ["default", "messenger-ipc"]
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcyQzk0MDdFNkU5RDQyNzkKUldSNVFwMXVma0RKY201M3pJaExRaWtMT1QycE9XOXczQjBkK0RXbXdxWkN0dE94dW5Nc0NsNksK",
      "endpoints": [
        "https://github.com/MIgoUserlife/signalist/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": [
      "icons/icon.png"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
